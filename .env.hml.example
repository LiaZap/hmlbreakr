# ─────────────────────────────────────────────────────────────────────────────
# .env.hml.example — ambiente do HML (Homologação) do Breaker.
#
# No EasyPanel, estas variáveis vão no Environment de cada serviço:
#   • db    → POSTGRES_*            (serviço Postgres)
#   • minio → MINIO_ROOT_*          (serviço MinIO)
#   • app   → todo o resto          (serviço App)
#
# Em deploy via docker-compose.hml.yml, copie este arquivo para `.env` (raiz).
# NUNCA commite o `.env` com valores reais. No HML use chaves de TESTE.
#
# Legenda: [BOOT] = sem isso o app NÃO sobe · [FEATURE] = só quebra a feature
#          se faltar · [INFRA] = preenchido com host interno do EasyPanel.
# ─────────────────────────────────────────────────────────────────────────────

# ═══ SERVIÇO db (Postgres 17) ════════════════════════════════════════════════
POSTGRES_DB=breaker_hml
POSTGRES_USER=breaker
POSTGRES_PASSWORD=TROQUE_senha-forte-do-postgres

# ═══ SERVIÇO minio (object storage) ══════════════════════════════════════════
MINIO_ROOT_USER=breaker-minio
MINIO_ROOT_PASSWORD=TROQUE_senha-forte-do-minio

# ═══ SERVIÇO app ═════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=3001

# ── Banco [BOOT] — host INTERNO do serviço db (<project>_db). Confirme no EasyPanel. ──
DATABASE_URL=postgres://breaker:TROQUE_senha-forte-do-postgres@breakerhml_db:5432/breaker_hml

# ── Auth admin [BOOT] — ADMIN_TOKEN >= 32 chars. Gere com:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" ──
ADMIN_TOKEN=TROQUE_hex-de-32-bytes

# ── SMTP [BOOT: SMTP_PASS] — sem SMTP_PASS o app NÃO sobe (emailService) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=TROQUE_senha-smtp

# ── MinIO (imagens / F5) ──
#   MINIO_ENDPOINT  = host INTERNO [INFRA] (upload server-side; <project>_minio)
#   MINIO_PUBLIC_BASE_URL = domínio PÚBLICO (o que o navegador carrega; com /bucket)
#   Sem MinIO configurado o app sobe igual e lê a imagem do blob (fallback).
MINIO_ENDPOINT=breakerhml_minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=breaker-minio
MINIO_SECRET_KEY=TROQUE_senha-forte-do-minio
MINIO_BUCKET=breaker-images
MINIO_PUBLIC_BASE_URL=https://storage-hml.seudominio.com/breaker-images

# ── App / dono [RECOMENDADO] ──
APP_URL=https://hml.seudominio.com
SUPER_ADMIN_EMAIL=admin@seudominio.com
SUPER_ADMIN_PASSWORD=TROQUE_senha-super-admin
BACKUP_ENABLED=false

# ── Clerk (auth) [FEATURE] ──
CLERK_SECRET_KEY=sk_test_...

# ── Stripe (billing) [FEATURE] — chaves de TESTE no HML ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs (têm default no código; defina p/ os fluxos de checkout funcionarem):
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_CLIENT=
STRIPE_PRICE_AGENCY_BASIC=
STRIPE_PRICE_AGENCY_UNLIMITED=
STRIPE_PRICE_FISPAL=

# ── OpenAI (conciliação bancária IA) [FEATURE/OPCIONAL] ──
OPENAI_API_KEY=

# ── Asaas (gateway alternativo) [OPCIONAL] — só se usar Asaas ──
ASAAS_ENV=sandbox
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# ── Admin legado (logins fixos opcionais) [OPCIONAL] ──
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
COMMERCIAL_EMAIL=
COMMERCIAL_PASSWORD=
FINANCIAL_EMAIL=
FINANCIAL_PASSWORD=

# ═══ FRONTEND (Vite) — build-time. No EasyPanel, defina no serviço app ANTES do build ══
VITE_API_URL=https://hml.seudominio.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
