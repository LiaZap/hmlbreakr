# ─────────────────────────────────────────────────────────────────────────────
# .env.hml.example — template de ambiente do HML (Homologação).
# Copie para `.env` (na raiz, ao lado do docker-compose.hml.yml) e preencha.
# NUNCA commite o `.env` com valores reais. Rotacione qualquer segredo exposto.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados (Postgres do HML) ──
POSTGRES_DB=breaker_hml
POSTGRES_USER=breaker
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# ── Object storage (MinIO) — armazena as imagens (F5) ──
MINIO_ROOT_USER=breaker-minio
MINIO_ROOT_PASSWORD=troque-por-uma-senha-forte
MINIO_BUCKET=breaker-images
# URL pública por onde as imagens serão servidas (aponta pro MinIO/proxy do HML).
# Inclua o bucket no final. Ex: https://storage.hml.seudominio.com/breaker-images
MINIO_PUBLIC_BASE_URL=https://storage.hml.seudominio.com/breaker-images

# ── App / URLs ──
APP_URL=https://hml.seudominio.com
BACKUP_ENABLED=false

# ── Auth admin (ADMIN_TOKEN: mínimo 32 chars; gere com:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
ADMIN_TOKEN=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ── Clerk (auth) ──
CLERK_SECRET_KEY=

# ── SMTP (e-mails transacionais) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Stripe (billing) — use chaves de TESTE no HML ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── OpenAI (conciliação IA — opcional) ──
OPENAI_API_KEY=

# ── Frontend (Vite) — build-time. Em EasyPanel, defina no serviço do app.
#    (No compose, o build usa o .env da raiz se necessário.) ──
VITE_API_URL=https://hml.seudominio.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
