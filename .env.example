# ─────────────────────────────────────────────────────────────────────────
# .env.example (RAIZ) — template do ambiente do FRONTEND (Vite).
# Copie para `.env` e preencha. NUNCA commite o `.env` com valores reais.
# As variáveis do BACKEND ficam em server/.env (veja server/.env.example).
# ─────────────────────────────────────────────────────────────────────────

# Apenas vars com prefixo VITE_ são expostas ao client pelo Vite.

# URL base da API do backend (dev: http://localhost:3001)
VITE_API_URL=http://localhost:3001

# Clerk publishable key — PÚBLICA por design (pk_test_... em dev, pk_live_... em prod)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
