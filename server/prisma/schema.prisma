generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id                   String    @id @default(uuid())
  name                 String
  hash                 String    @unique
  email                String    @unique
  password             String
  resetToken           String?
  resetTokenAt         DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String    @default("basic") // basic | unlimited
  active               Boolean   @default(false)
  clients              Client[]  @relation("AgencyClients")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([active])
}

model Client {
  id                   String       @id @default(uuid())
  name                 String
  hash                 String       @unique
  email                String?      @unique
  password             String?
  resetToken           String?
  resetTokenAt         DateTime?
  clerkUserId          String?      @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  active               Boolean      @default(true)
  agencyId             String?
  agency               Agency?      @relation("AgencyClients", fields: [agencyId], references: [id])
  data                 String
  teamMembers          TeamMember[] @relation("ClientTeam")

  // BPO Financeiro V2.0
  bpoEnabled          Boolean              @default(false)
  bpoActivatedAt      DateTime?
  suppliers           Supplier[]
  bankAccounts        BankAccount[]
  financialCategories FinancialCategory[]
  bpoEmployees        BpoEmployee[]
  bpoPartners         BpoPartner[]
  paymentMethods      PaymentMethod[]
  receivableAdvances  ReceivableAdvance[]
  loans               Loan[]
  payables            Payable[]
  receivables         Receivable[]
  reconciliationRules ReconciliationRule[] @relation("ClientReconciliationRules")
  bankTransfers       BankTransfer[]       @relation("ClientBankTransfers")
  bpoTasks            BpoTask[]            @relation("ClientBpoTasks")
  whatsappMessages    WhatsappMessage[]    @relation("ClientWhatsappMessages")
  pdvIntegrations     PdvIntegration[]     @relation("ClientPdvIntegrations")
  dataSnapshots       ClientDataSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([active])
}

// Snapshots históricos do Client.data (JSON blob ~330KB) pra evitar perda
// de dados em saves acidentais/anômalos. Criado pós-incidente Garapas
// (2026-05-11) onde metade do data foi sobrescrito sem possibilidade de
// recuperação. Cada save no /client/:hash/sync gera um snapshot antes;
// pruneOldSnapshots mantém só os N mais recentes (default 20).
model ClientDataSnapshot {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  data      String // JSON snapshot do Client.data
  size      Int // bytes — pra detectar saves anômalos (size diminuiu muito)
  reason    String? // 'auto' | 'pre-onboarding-save' | 'manual' | 'auto-shrink-detected' | 'pre-restore' | etc
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
}

// Funcionários Breakr — admins/operadores que acessam o painel administrativo.
// Antes ADMIN_ACCOUNTS era hardcoded em routes.js, agora pode ser gerenciado
// via UI por super_admin. Login via email+senha (bcrypt) ou Clerk SSO.
model AdminUser {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String? // bcrypt hash, opcional se usa Clerk
  clerkUserId String?   @unique
  role        String // super_admin | admin | gestor | commercial | financial | custom
  permissions String[]  @default([]) // granular — ex: ['dashboard.view','clients.edit']. Vazio = usa template do role.
  photo       String?   @db.Text
  active      Boolean   @default(true)
  invitedBy   String? // id do super_admin que convidou
  invitedAt   DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@index([active])
}

model TeamMember {
  id          String   @id @default(uuid())
  name        String
  hash        String   @unique
  email       String   @unique
  password    String?
  clerkUserId String?  @unique
  role        String   @default("Gerente")
  clientId    String
  client      Client   @relation("ClientTeam", fields: [clientId], references: [id], onDelete: Cascade)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
}

model Broadcast {
  id             String    @id @default(uuid())
  title          String
  message        String
  imageUrl       String?
  type           String    @default("popup") // popup | banner
  active         Boolean   @default(true)
  targetCategory String? // null = all, or "Pizzaria", "Hamburgueria", etc.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  expiresAt      DateTime?

  @@index([active])
  @@index([targetCategory])
}

// =====================================================================
// BPO FINANCEIRO — Fase 1 (Cadastros + Lançamentos Manuais)
// Adicionado em 2026-04-27. Documentação:
// [[Breakr V2.0 - Plano de Acao BPO Financeiro]]
// =====================================================================

model Supplier {
  id                   String             @id @default(uuid())
  clientId             String
  client               Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cnpj                 String
  name                 String
  email                String?
  phone                String?
  pixKey               String?
  bankCode             String?
  agency               String?
  account              String?
  defaultCategoryId    String?
  defaultCategory      FinancialCategory? @relation("SupplierDefaultCategory", fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  defaultBankAccountId String?
  defaultBankAccount   BankAccount?       @relation("SupplierDefaultBankAccount", fields: [defaultBankAccountId], references: [id], onDelete: SetNull)
  notes                String?
  payables             Payable[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([clientId, cnpj])
  @@index([clientId])
}

model BankAccount {
  id                   String               @id @default(uuid())
  clientId             String
  client               Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bankCode             String // 001=BB, 237=Bradesco, 341=Itaú, etc.
  bankName             String
  agency               String
  account              String
  type                 String               @default("corrente") // corrente | poupanca | pagamento
  currentBalance       Decimal              @default(0) @db.Decimal(18, 2)
  isManual             Boolean              @default(true)
  // Open Finance (Fase 3)
  openFinanceItemId    String? // Pluggy item ID
  openFinanceConnected Boolean              @default(false)
  lastSyncAt           DateTime?
  active               Boolean              @default(true)
  suppliersDefault     Supplier[]           @relation("SupplierDefaultBankAccount")
  payments             PaymentTransaction[]
  bankTransactions     BankTransaction[]    @relation("BankAccountTransactions")
  transfersFrom        BankTransfer[]       @relation("TransferFromAccount")
  transfersTo          BankTransfer[]       @relation("TransferToAccount")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([clientId])
}

model FinancialCategory {
  id               String              @id @default(uuid())
  clientId         String
  client           Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  type             String // receita | despesa
  parentId         String?
  parent           FinancialCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         FinancialCategory[] @relation("CategoryHierarchy")
  dreGroup         String? // cmv | despesa_op | taxa_venda | imposto | pro_labore | receita | outros
  color            String? // hex pra dashboard
  active           Boolean             @default(true)
  suppliersDefault Supplier[]          @relation("SupplierDefaultCategory")
  payables         Payable[]
  receivables      Receivable[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([clientId])
}

model BpoEmployee {
  id             String    @id @default(uuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  cpf            String?
  email          String?
  phone          String?
  // Dados bancários
  bankCode       String?
  agency         String?
  account        String?
  pixKey         String?
  // Cargo
  role           String // Cozinha | Salão | Administrativo | Entrega
  isFreelancer   Boolean   @default(false)
  isMotoboy      Boolean   @default(false)
  baseSalary     Decimal?  @db.Decimal(18, 2)
  // Variáveis (mensal)
  commissionPct  Decimal?  @db.Decimal(5, 2)
  tipsAmount     Decimal?  @db.Decimal(18, 2)
  overtimeAmount Decimal?  @db.Decimal(18, 2)
  active         Boolean   @default(true)
  hiredAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([clientId, cpf])
  @@index([clientId])
}

model BpoPartner {
  id                    String   @id @default(uuid())
  clientId              String
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name                  String
  cpf                   String?
  email                 String?
  phone                 String?
  prolaboreAmount       Decimal  @db.Decimal(18, 2)
  // Conta corrente pessoal — depois do prolabore atingido, vira "Retirada de Capital"
  personalAccountBank   String?
  personalAccountAgency String?
  personalAccountNumber String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([clientId, cpf])
  @@index([clientId])
}

model PaymentMethod {
  id             String              @id @default(uuid())
  clientId       String
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String // iFood, Aiqfome, Crédito, Débito, PIX, Dinheiro
  type           String // marketplace | card_credit | card_debit | pix | cash | transfer
  feePercent     Decimal             @default(0) @db.Decimal(5, 2)
  settlementDays Int                 @default(0)
  active         Boolean             @default(true)
  receivables    Receivable[]
  advances       ReceivableAdvance[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([clientId])
}

// BAH-031 — Empréstimos e Financiamentos
// Cliente registra contratos com bancos pra ter parcela mensal e saldo
// devedor refletidos na DRE/fluxo de caixa.
model Loan {
  id                  String   @id @default(uuid())
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bankName            String
  contractNumber      String?
  description         String? // ex: "Capital de giro - reforma"
  // Inputs
  principal           Decimal  @db.Decimal(18, 2) // valor financiado
  interestRateMonthly Decimal  @db.Decimal(7, 4) // taxa a.m. (% ao mês)
  totalInstallments   Int // qtd total de parcelas
  paidInstallments    Int      @default(0) // qtd ja pagas
  startDate           DateTime
  // Calculados (denormalizados pra performance)
  installmentValue    Decimal  @db.Decimal(18, 2) // valor da parcela (Price)
  totalToPay          Decimal  @db.Decimal(18, 2) // installmentValue * totalInstallments
  totalInterest       Decimal  @db.Decimal(18, 2) // totalToPay - principal
  currentBalance      Decimal  @db.Decimal(18, 2) // saldo devedor amortizado
  status              String   @default("active") // active | paid | cancelled
  notes               String?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([clientId])
  @@index([status])
}

// BAH-030 — Antecipação de Recebíveis
// Cliente cadastra antecipações que faz nas operadoras (cartão/marketplace)
// pra ver o quanto perde em taxa e ter isso refletido no "Dinheiro na Mesa".
model ReceivableAdvance {
  id              String         @id @default(uuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  // Identificação opcional (ex: "iFood antecipação semanal")
  description     String
  // Inputs
  monthlyRate     Decimal        @db.Decimal(7, 4) // taxa a.m. (% ao mês), ex: 2.99
  averageValue    Decimal        @db.Decimal(18, 2) // valor médio antecipado por mês (R$)
  daysAdvanced    Int // dias antecipados (média)
  // Calculados (denormalizados pra historico)
  dailyRate       Decimal        @db.Decimal(9, 6) // taxa equivalente diária (decimal)
  totalDiscount   Decimal        @db.Decimal(18, 2) // valor R$ perdido em taxa
  finalValue      Decimal        @db.Decimal(18, 2) // valor liquido apos desconto
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clientId])
}

model Payable {
  id                String               @id @default(uuid())
  clientId          String
  client            Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplierId        String?
  supplier          Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  amount            Decimal              @db.Decimal(18, 2)
  remainingAmount   Decimal              @db.Decimal(18, 2) // pra pagamento parcial
  dueDate           DateTime
  paymentForecast   DateTime
  emissionDate      DateTime?
  invoiceNumber     String?
  description       String?
  categoryId        String?
  category          FinancialCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  department        String?
  status            String               @default("pending") // pending | scheduled | paid_partial | paid | cancelled
  // Recorrência / Parcelamento
  recurrenceId      String?
  recurrence        Recurrence?          @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  parentId          String? // pra parcelas (parcela 2/12 → parent é a 1ª)
  parent            Payable?             @relation("PayableInstallments", fields: [parentId], references: [id], onDelete: Cascade)
  installments      Payable[]            @relation("PayableInstallments")
  installmentNumber Int?
  // Anexos & impostos retidos
  attachments       String? // JSON array: [{ filename, url, type, sizeKb }]
  taxesRetained     String? // JSON: { ir, csll, pis, cofins, iss }
  // Agendamento bancário
  scheduledAt       DateTime?
  scheduledBankId   String?
  scheduledStatus   String? // none | sent | approved | rejected
  // Aprovação pelo dono (workflow BPO operador agenda → dono aprova)
  requiresApproval  Boolean              @default(false)
  approvedAt        DateTime?
  approvedBy        String? // email do aprovador (dono)
  rejectedAt        DateTime?
  rejectionReason   String?
  // Audit
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  payments          PaymentTransaction[] @relation("PaymentToPayable")

  @@index([clientId, status, dueDate])
  @@index([supplierId])
}

model Receivable {
  id                String               @id @default(uuid())
  clientId          String
  client            Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payerName         String // cliente final do restaurante (pode ser "iFood", "Cliente avulso", etc.)
  payerDocument     String?
  amount            Decimal              @db.Decimal(18, 2)
  remainingAmount   Decimal              @db.Decimal(18, 2)
  dueDate           DateTime
  receiptForecast   DateTime
  emissionDate      DateTime?
  invoiceNumber     String?
  description       String?
  categoryId        String?
  category          FinancialCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  paymentMethodId   String?
  paymentMethod     PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  department        String?
  status            String               @default("pending") // pending | received_partial | received | cancelled
  recurrenceId      String?
  recurrence        Recurrence?          @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  parentId          String?
  parent            Receivable?          @relation("ReceivableInstallments", fields: [parentId], references: [id], onDelete: Cascade)
  installments      Receivable[]         @relation("ReceivableInstallments")
  installmentNumber Int?
  // PDV (Fase 5)
  pdvSaleId         String?
  attachments       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  payments          PaymentTransaction[] @relation("PaymentToReceivable")

  @@index([clientId, status, dueDate])
}

model Recurrence {
  id               String       @id @default(uuid())
  frequency        String // weekly | monthly | quarterly | semiannual | yearly
  intervalCount    Int          @default(1)
  startDate        DateTime
  endDate          DateTime?
  occurrencesCount Int? // null = indefinido
  payables         Payable[]
  receivables      Receivable[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([startDate])
}

model PaymentTransaction {
  id            String      @id @default(uuid())
  payableId     String?
  payable       Payable?    @relation("PaymentToPayable", fields: [payableId], references: [id], onDelete: Cascade)
  receivableId  String?
  receivable    Receivable? @relation("PaymentToReceivable", fields: [receivableId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(18, 2)
  paidAt        DateTime
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  isPartial     Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([payableId])
  @@index([receivableId])
  @@index([bankAccountId, paidAt])
}

// =====================================================================
// BPO Fase 3 (parcial — sem APIs externas ainda) + Fase 4 Painel BPO
// Conciliação bancária manual + Transferências entre contas + Tarefas BPO
// =====================================================================

model BankTransaction {
  id             String      @id @default(uuid())
  bankAccountId  String
  bankAccount    BankAccount @relation("BankAccountTransactions", fields: [bankAccountId], references: [id], onDelete: Cascade)
  externalId     String? // FITID do OFX ou Pluggy itemId futuro
  amount         Decimal     @db.Decimal(18, 2)
  date           DateTime
  description    String
  type           String      @default("debit") // debit | credit
  // Conciliação: vinculado a Payable, Receivable, BankTransfer ou nulo
  reconciledType String? // payable | receivable | transfer | manual_ignored
  reconciledId   String? // id do que foi vinculado
  reconciledAt   DateTime?
  source         String      @default("manual") // manual | ofx | csv | openfinance
  rawJson        String?
  createdAt      DateTime    @default(now())

  @@index([bankAccountId, date])
  @@index([reconciledType, reconciledId])
}

model ReconciliationRule {
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation("ClientReconciliationRules", fields: [clientId], references: [id], onDelete: Cascade)
  keyword       String
  matchType     String   @default("contains") // contains | starts | exact | regex
  supplierId    String?
  payerName     String?
  categoryId    String?
  bankAccountId String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clientId, active])
}

model BankTransfer {
  id            String      @id @default(uuid())
  clientId      String
  client        Client      @relation("ClientBankTransfers", fields: [clientId], references: [id], onDelete: Cascade)
  fromAccountId String
  fromAccount   BankAccount @relation("TransferFromAccount", fields: [fromAccountId], references: [id])
  toAccountId   String
  toAccount     BankAccount @relation("TransferToAccount", fields: [toAccountId], references: [id])
  amount        Decimal     @db.Decimal(18, 2)
  date          DateTime
  description   String?
  fee           Decimal     @default(0) @db.Decimal(18, 2) // taxa TED/DOC
  createdAt     DateTime    @default(now())

  @@index([clientId, date])
}

model BpoTask {
  id          String    @id @default(uuid())
  clientId    String
  client      Client    @relation("ClientBpoTasks", fields: [clientId], references: [id], onDelete: Cascade)
  type        String // overdue_payable | overdue_receivable | unconciliated_tx | whatsapp_pending | manual
  severity    String    @default("normal") // low | normal | high | critical
  title       String
  description String?
  relatedType String? // payable | receivable | bank_transaction
  relatedId   String?
  dueAt       DateTime?
  status      String    @default("open") // open | in_progress | resolved | dismissed
  resolvedAt  DateTime?
  assignedTo  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId, status])
  @@index([status, severity, dueAt])
}

// =====================================================================
// BPO Fase 5 (stub — aguarda contratos Z-API e PDVs)
// Schema preparado pra plugar quando APIs externas estiverem ativas
// =====================================================================

model WhatsappMessage {
  id                  String    @id @default(uuid())
  clientId            String? // null inicial; bot identifica depois
  client              Client?   @relation("ClientWhatsappMessages", fields: [clientId], references: [id], onDelete: SetNull)
  fromNumber          String // +55XXXXXXXXX
  senderName          String?
  messageType         String    @default("text") // text | image | document | audio
  textContent         String?
  mediaUrl            String? // imagens/PDFs
  mediaCaption        String?
  conversationStep    String? // identifying | choosing_doc_type | choosing_launch | choosing_account | confirm
  conversationData    String? // JSON com escolhas parciais
  validatedAt         DateTime?
  validatedBy         String? // email do operador BPO
  createdPayableId    String?
  createdReceivableId String?
  status              String    @default("pending") // pending | validated | discarded
  rawJson             String? // payload bruto do webhook Z-API
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([clientId, status])
  @@index([fromNumber])
  @@index([status, createdAt])
}

model PdvIntegration {
  id             String    @id @default(uuid())
  clientId       String
  client         Client    @relation("ClientPdvIntegrations", fields: [clientId], references: [id], onDelete: Cascade)
  provider       String // suitable | colibri | linx | saipos | outro
  authConfig     String // JSON: { apiKey, baseUrl, etc }
  active         Boolean   @default(true)
  lastSyncAt     DateTime?
  lastSyncStatus String? // ok | error
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([clientId, active])
}
