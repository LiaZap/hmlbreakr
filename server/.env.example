# ============================================================================
# .env.example — Variáveis de ambiente do server (Breaker BPO)
# Copie para .env e preencha. Nunca commitar .env real.
# ============================================================================

# === Database ===
DATABASE_URL="postgresql://user:pass@localhost:5432/breakr"

# === HTTP ===
PORT=3001
APP_URL=http://localhost:5173

# === Admin accounts (fallback) ===
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_PASSWORD=
COMMERCIAL_EMAIL=
COMMERCIAL_PASSWORD=
FINANCIAL_EMAIL=
FINANCIAL_PASSWORD=

# === SMTP (Hostinger) ===
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@breakr.com.br
SMTP_PASS=

# === Clerk (auth) ===
CLERK_SECRET_KEY=

# === Stripe (pagamentos / trial) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === OpenAI (BPO — sugestão de conciliação com IA) ===
# Opcional. Sem ele, conciliação usa word-match (matching por palavra-chave + valor).
# Quando preenchido, o endpoint /reconciliation/suggest aciona gpt-4o-mini
# para refinar matches de baixa confiança ou empatados.
OPENAI_API_KEY=
